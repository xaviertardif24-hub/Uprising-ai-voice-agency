4# ============================================
# SYSTÈME DE RÉCEPTIONNISTE IA
# Variables d'environnement (code/)
# ============================================

# --- Serveur ---
PORT=3000
NODE_ENV=development

# --- Bland AI ---
BLAND_AI_API_KEY=your_bland_ai_api_key_here
BLAND_AI_PHONE_NUMBER=+15551234567
BLAND_AI_WEBHOOK_URL=https://your-server.com/webhook/bland-ai

# --- Twilio ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15559876543

# --- Google Calendar ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here
GOOGLE_CALENDAR_ID=your_calendar_id@gmail.com

# --- Airtable ---
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_NAME=Prospects

# --- Notifications ---
OWNER_PHONE_NUMBER=+15551112222
OWNER_EMAIL=owner@example.com

# --- Entreprise ---
BUSINESS_NAME="Votre Entreprise Inc."
BUSINESS_PHONE=+15553334444
TRANSFER_PHONE_NUMBER=+15553334444

# --- CORS (production) ---
ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com
