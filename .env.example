# AI Receptionist Configuration — Copy this file to .env and fill in your values.
# NEVER commit your real .env file to Git!

# Server
PORT=3000
NODE_ENV=development

# Bland AI (required for voice calls)
BLAND_AI_API_KEY=
BLAND_AI_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/webhook/bland-ai
BLAND_AI_WEBHOOK_SECRET=your-strong-secret-here

# ElevenLabs (optional — for realistic voices)
ELEVENLABS_API_KEY=

# Twilio (optional — for SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Phone number to call for testing
PHONE_NUMBER_TO_CALL=

# Google Calendar (required for appointment booking)
CALENDAR_ID=your_email@gmail.com
# OR provide the full JSON credentials as a string:
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Twenty CRM (optional)
TWENTY_API_KEY=
TWENTY_API_URL=https://api.twenty.com/v1

# Email notifications (SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# Fonoster SMS (optional open-source SMS)
FONOSTER_PROJECT=
FONOSTER_TOKEN=
FONOSTER_FROM_NUMBER=

# CORS — comma-separated list of allowed origins (leave blank = allow all in dev)
ALLOWED_ORIGINS=http://localhost:3000

# Voice Provider: 'bland' or 'dograh'
VOICE_PROVIDER=bland
